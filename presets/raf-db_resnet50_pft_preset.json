{
  "dataset": "RAF-DB",
  "model": "ResNet50",
  "strategy": "pft",
  "learning_rate": 1e-4, 
  "batch_size": 64,
  "epochs": 80,
  "dropout_conv": null,
  "dropout_dense": 0.5,
  "weight_decay": 1e-4,
  "dense_units": 256,
  "augmentation": {
    "enabled": true,
    "rotation_range": 20,
    "width_shift_range": 0.15,
    "height_shift_range": 0.15,
    "zoom_range": 0.2,
    "brightness_range": [0.7, 1.3],
    "shear_range": 0.15,
    "horizontal_flip": true,
    "fill_mode": "nearest"
  },
  "callbacks": {
    "early_stopping": {
      "enabled": true,
      "patience": 15,
      "min_delta": 5e-4
    },
    "reduce_lr": {
      "enabled": true,
      "patience": 5,
      "factor": 0.5,
      "min_lr": 1e-7
    }
  }
}